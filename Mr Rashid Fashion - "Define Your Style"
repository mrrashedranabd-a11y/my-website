<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Rashed Brand Store</title>

<style>
body{margin:0;font-family:Arial;background:#0f172a;color:white;}
header{padding:20px;text-align:center;background:#020617;}
.products{display:flex;flex-wrap:wrap;justify-content:center;padding:20px;}
.card{
  background:#020617;
  margin:15px;
  padding:15px;
  width:250px;
  border-radius:10px;
  text-align:center;
}
.card img{width:100%;}
button{
  margin-top:10px;
  padding:10px;
  width:100%;
  background:#38bdf8;
  border:none;
  cursor:pointer;
}
.checkout{
  display:none;
  padding:20px;
}
input,select{
  width:100%;
  padding:8px;
  margin:5px 0;
}
</style>
</head>

<body>

<header>
  <h1>Rashed Brand Store 🛒</h1>
</header>

<div class="products">

  <div class="card">
    <img src="https://via.placeholder.com/250">
    <h3>T-Shirt</h3>
    <p>৳500</p>
    <button onclick="openCheckout('T-Shirt',500)">Buy Now</button>
  </div>

  <div class="card">
    <img src="https://via.placeholder.com/250">
    <h3>Shoes</h3>
    <p>৳1200</p>
    <button onclick="openCheckout('Shoes',1200)">Buy Now</button>
  </div>

</div>

<!-- Checkout -->
<div class="checkout" id="checkout">
  <h2>Checkout</h2>

  <input id="name" placeholder="Your Name">
  <input id="phone" placeholder="Phone Number">
  <input id="address" placeholder="Address">

  <select id="payment">
    <option>bKash</option>
    <option>Nagad</option>
    <option>Rocket</option>
    <option>Upay</option>
  </select>

  <p id="productInfo"></p>

  <button onclick="orderNow()">Confirm Order</button>
</div>

<script>
let productName="";
let productPrice=0;

function openCheckout(name,price){
  productName=name;
  productPrice=price;
  document.getElementById("checkout").style.display="block";
  document.getElementById("productInfo").innerHTML=
    "Product: "+name+" | Price: ৳"+price+
    "<br><br>Send Money to: 01614298617";
}

function orderNow(){
  let name=document.getElementById("name").value;
  let phone=document.getElementById("phone").value;
  let address=document.getElementById("address").value;
  let payment=document.getElementById("payment").value;

  let msg=
  "Order Details:%0A"+
  "Name: "+name+"%0A"+
  "Phone: "+phone+"%0A"+
  "Address: "+address+"%0A"+
  "Product: "+productName+"%0A"+
  "Price: ৳"+productPrice+"%0A"+
  "Payment: "+payment;

  window.open("https://wa.me/8801614298617?text="+msg);
}
</script>

</body>
  </html>
